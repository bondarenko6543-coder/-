import requests
from bs4 import BeautifulSoup
import sqlite3
import time



conn = sqlite3.connect('quo3tes.db')
c = conn.cursor()
#оздание таблицы если такой нету
c.execute('''CREATE TABLE IF NOT EXISTS quotes (
id INTEGER PRIMARY KEY AUTOINCREMENT,
text TEXT,
author TEXT,
author_lin TEXT,
tags  TEXT,
UNIQUE(text, author)
)''')

for page in range(1,11):
    time.sleep(1)
    url = f'http://quotes.toscrape.com/page/{page}/'
    success = False
    headers = {'User-Agent': 'Mozilla/5.0'}
#проверки на ошыбки
    for attemp in range(3):
        try:
            response = requests.get(url, headers=headers, timeout=10)
            if response.status_code == 200:
                success = True
                break
            elif response.status_code == 403:
                print(f'Ошибка 403, попытка {attemp + 1}')
                time.sleep(60)
            else:
                print(f'ошыбка {response.status_code}')
                break
        except requests.exceptions.RequestException as e:
            print(f'Сетевая ошибка: {e}')
            time.sleep(10)
    if not success:
        print(f'Пропускаем страницу {page} (не удалось загрузить)')
        continue
    soup = BeautifulSoup(response.content, 'html.parser')
    full_quotes = soup.find_all('div', class_='quote')
    #цыкл поиска всех даных
    for quote in full_quotes:
        text = quote.find('span', class_='text')
        author = quote.find('small', class_='author')
        author_lin = quote.find('a')['href']
        tags = quote.find_all('a', class_='tag')
        #делам с тега список что бы добавлять с комой и без ошибок
        tags_foll_text = []
        for tag in tags:
            tags_foll_text.append(tag.text)
        #добавляем все даные без повтора
        c.execute("""
        INSERT OR IGNORE INTO quotes (text, author, author_lin, tags)
         VALUES (?, ?, ?, ?)""", (text.text, author.text, author_lin, (', ').join(tags_foll_text)))

conn.commit()
conn.close()
