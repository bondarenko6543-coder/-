from bs4 import BeautifulSoup as bs
import requests
import time
import sqlite3

file = 'books2.db'
coon = sqlite3.connect(file)
cursor = coon.cursor()

#создали таблицу
cursor.execute("""CREATE TABLE IF NOT EXISTS books (
id INTEGER PRIMARY KEY AUTOINCREMENT,
 title TEXT,
    price  REAL,
    rating INTEGER,
    in_stock INTEGER,
    URL TEXT UNIQUE
    )""")
#парсинг страниц
for page in range(1,51):
    time.sleep(1)
    url = f'https://books.toscrape.com/catalogue/page-{page}.html'
    response = requests.get(url)
    soup = bs(response.text, 'html.parser')

    books = soup.find_all('li', class_='col-xs-6 col-sm-4 col-md-3 col-lg-3')

    for book in books:
        title = book.find('h3').text
        price = book.find("p", {"class": "price_color"})
        price = float(price.text.replace('Â£', '').strip())
        in_stock = book.find('p', class_='instock availability').text
        # делаем наличие числами 0,1
        if in_stock.strip() == 'In stock':
            in_stock = 1
        else :
            in_stock = 0
        rating = book.find('p', {'class':'star-rating'})

        #делаем оценку числами
        classes = rating.get('class')
        rating_text = classes[1]
        rating_map = {
            "One": 1,
            "Two": 2,
            "Three": 3,
            "Four": 4,
            "Five": 5,
        }
        rating = rating_map.get(rating_text,0)

        url_book = 'https://books.toscrape.com/catalogue/' + book.find('a')['href']
        #добавляем все в таблицу
        cursor.execute("""
            INSERT OR IGNORE INTO books (title, price, rating, in_stock, url)
            VALUES (?, ?, ?, ?, ?)
        """, (title, price, rating, in_stock, url_book))

coon.commit()
cursor.close()
coon.close()

print(f'код успешно выполнен файл таблицы создан: {file}')
