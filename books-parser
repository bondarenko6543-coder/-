#проверка на ошибки сети или не отвечает сайт
def examination(url):
    success = False
    for eror in range(3):
        response = requests.get(url, headers=headers, timeout=10)
        try:
            if response.status_code == 200:
                success = True
                break
            elif response.status_code == 404:
                print(eror + 1)
                time.sleep(60)
            else:
                print(f'ошибка {response.status_code}')
        except requests.exceptions.RequestException as e:
            print(f'сетивая ошибка {e}')
            time.sleep(10)
    return success

#переходим на категории находим все сылки на книги
def link_to_books(url_categories):
    books_url_all = []
    if examination(url_categories) == True:
        response = requests.get(url_categories, headers=headers, timeout=10)
        soup = BeautifulSoup(response.content, 'html.parser')
        books = soup.find_all('li', class_='col-xs-6 col-sm-4 col-md-3 col-lg-3')
        for book in books:
            books_url = book.find('h3').find('a')['href']
            books_url = 'https://books.toscrape.com/catalogue' + str(books_url[8:])
            books_url_all.append(books_url)
        return books_url_all
    else: return False

#находи все нужные даные
def result_books(books_url):
    name_result = []
    price_result = []
    availability_result = []
    rating_result = []
    upc_result = []
    Product_Information_result = []
    for book_url in books_url:
        if examination(book_url) == True:
            response = requests.get(book_url, headers=headers, timeout=10)
            soup = BeautifulSoup(response.content, 'html.parser')
            name = soup.find('div', class_='col-sm-6 product_main').find('h1')
            price = soup.find('p', class_='price_color')
            availability = soup.find('p', class_='instock availability')
            upc = soup.find('table', class_='table table-striped').find('tr')
            Product_Information = soup.find('article', class_='product_page').find_all('p')[3]
            rating = soup.find('p', class_='star-rating')
            classes = rating.get('class')
            rating_text = classes[1]
            rating_map = {
                "One": 1,
                "Two": 2,
                "Three": 3,
                "Four": 4,
                "Five": 5,
            }
            rating = rating_map.get(rating_text, 0)
            rating_result.append(rating)
            name_result.append(name.text)
            price_result.append(price.text[1:])
            availability_result.append(availability.text.strip())
            upc_result.append(upc.text[3:][:-2])
            Product_Information_result.append(Product_Information.text)
        else: return False
    return name_result, price_result, availability_result, rating_result, upc_result, Product_Information_result, books_url

#создаем таблицу
conn = sqlite3.connect('books.db')
