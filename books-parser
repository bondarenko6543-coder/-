    if result_chak == False:
        print('ОШЫБКА!!!')
        break
        #если ок идем дальше
    if result_chak:
        soup = BeautifulSoup(response.content, 'html.parser')
        categories = soup.find_all('ul', class_='nav nav-list')

        number_of_pages = []

        for cate in categories:
            for cat in cate.find('li').find_all('li'):
                number_of_pages.append(cat.find('a')['href'])
        for page in range(len(number_of_pages)):
            url_categories = 'https://books.toscrape.com/catalogue/category'+str(number_of_pages[page][2:])
            response = requests.get(url_categories, headers=headers, timeout=10)
            soup = BeautifulSoup(response.content, 'html.parser')
