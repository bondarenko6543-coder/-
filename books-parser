            full_url_categories.append(url_categories)
            if next_page != None:
                peg = 2
                #если несколько листов страницы переходим на следуйшею
                while True:
                    url_categories_gwf = url_categories.replace("index.html", f"page-{peg}.html")
                    response = requests.get(url_categories_gwf, headers=headers, timeout=10)
                    soup = BeautifulSoup(response.content, 'html.parser')
                    next_page = soup.find('li', class_='next')
                    full_url_categories.append(url_categories_gwf)
                    #print(result_books(link_to_books(url_categories)))
                    peg += 1
                    if next_page == None:
                        break
